# Go Kilimanjaro Treks — Cloudflare Pages Headers

# Fonts: immutable, cached forever (filenames never change after deploy)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Images: 30 days
/images/*
  Cache-Control: public, max-age=2592000

# JS: 1 year (bump filename to bust cache on updates)
/main.js
  Cache-Control: public, max-age=31536000, immutable

# HTML: 1 hour so updates appear quickly
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

/
  Cache-Control: public, max-age=3600, must-revalidate

# Security headers on everything
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Dev files: keep them out of search results
/download_photos.py
  X-Robots-Tag: noindex, nofollow

/PHOTOS.md
  X-Robots-Tag: noindex, nofollow
