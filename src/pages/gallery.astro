afari-28-0652-024.jpg","caption":"Children of the Maasai village.","category":"Culture"},{"slug":"safari-28-0706-025.jpg","caption":"Maasai shukas in the cultural visit.","category":"Culture"},{"slug":"safari-28-0739-026.jpg","caption":"Inside a Maasai boma.","category":"Culture"},{"slug":"safari-28-0745-027.jpg","caption":"A safari moment captured between sightings.","category":"Safari"},{"slug":"safari-28-0759-028.jpg","caption":"Tanzania safari scenery.","category":"Safari"},{"slug":"safari-28-0803-029.jpg","caption":"Open plains and distant cloud cover.","category":"Safari"},{"slug":"safari-28-0812-030.jpg","caption":"Lake Manyara reflections.","category":"Safari"},{"slug":"safari-28-0822-031.jpg","caption":"Sunrise viewpoint above the cloud sea.","category":"Safari"},{"slug":"safari-28-0824-032.jpg","caption":"Bird life in the canopy.","category":"Safari"},{"slug":"safari-28-0848-033.jpg","caption":"Game drive through Tarangire.","category":"Safari"},{"slug":"safari-28-1125-034.jpg","caption":"Acacia tree on the Tarangire plain.","category":"Safari"},{"slug":"safari-28-1135-035.jpg","caption":"Ngorongoro crater floor wildlife.","category":"Safari"},{"slug":"safari-28-1137-036.jpg","caption":"Wildflowers along the safari trail.","category":"Safari"},{"slug":"safari-28-1138-037.jpg","caption":"A baobab tree silhouette.","category":"Safari"},{"slug":"safari-28-1218-038.jpg","caption":"Safari camp at golden hour.","category":"Safari"},{"slug":"safari-28-1331-039.jpg","caption":"Vista from the safari vehicle.","category":"Safari"},{"slug":"safari-29-0754-040.jpg","caption":"A pause for refreshments on the safari.","category":"Safari"},{"slug":"safari-29-0817-041.jpg","caption":"Stargazing at the safari camp.","category":"Safari"},{"slug":"safari-29-1054-042.jpg","caption":"Morning breakfast outside the tent.","category":"Safari"},{"slug":"safari-ff-PXL-043.jpg","caption":"Sunrise on the Serengeti plains.","category":"Safari"}];

const CATEGORIES = ["All", "Routes", "Crew", "Camps", "Mountains", "Glacier", "Safari", "Culture", "Day Trips", "Climbers"];

const ldImages = PHOTOS.map(p => ({
  "@type": "ImageObject",
  "contentUrl": `https://gokilimanjarotreks.com/images/gallery/${p.slug}`,
  "description": p.caption,
  "creditText": "Go Kilimanjaro Treks"
}));

const galleryLd = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  "url": "https://gokilimanjarotreks.com/gallery",
  "name": "Go Kilimanjaro Treks Photo Gallery",
  "description": "Original photography from Mount Kilimanjaro climbs and northern Tanzania safaris with Go Kilimanjaro Treks.",
  "image": ldImages,
  "publisher": {"@id": "https://gokilimanjarotreks.com/#organization"}
};
---

<BaseLayout
  title="Photo Gallery: Kilimanjaro Climbs & Tanzania Safaris | Go Kilimanjaro Treks"
  description="Original photography from Mount Kilimanjaro climbs and northern Tanzania safaris. Routes, camps, the mountain crew, glaciers, and wildlife."
  ogImage="https://gokilimanjarotreks.com/images/gallery/summit-celebration-group.jpg"
  ogImageAlt="Climbers celebrating at altitude on Mount Kilimanjaro"
  schemas={[galleryLd]}
>

<section class="gal-hero">
  <div class="container">
    <span class="eyebrow">From the Mountain</span>
    <h1>The <em>Gallery.</em></h1>
    <p>Original photography from Mount Kilimanjaro climbs and northern Tanzania safaris. Tap any photo to view larger.</p>
  </div>
</section>

<section class="gal-controls">
  <div class="container">
    <div class="gal-filters" role="tablist" aria-label="Filter photos by category">
      {CATEGORIES.map((cat) => (
        <button class={"gal-filter" + (cat === "All" ? " active" : "")} data-cat={cat}>{cat}</button>
      ))}
    </div>
  </div>
</section>

<section class="gal-grid-wrap">
  <div class="container">
    <div class="gal-grid" id="gal-grid">
      {PHOTOS.map((p, i) => (
        <a class="gal-card" data-cat={p.category} data-idx={i} href={`/images/gallery/${p.slug}`} aria-label={`View larger: ${p.caption}`}>
          <picture>
            <source type="image/webp" srcset={`/images/gallery/${p.slug.replace('.jpg','.webp')}`} />
            <img src={`/images/gallery/${p.slug}`} alt={p.caption} loading="lazy" />
          </picture>
          <div class="gal-meta"><span class="gal-cat">{p.category}</span>{p.caption}</div>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <div class="reveal">
      <h2>Make Your Own <em>Photos.</em></h2>
      <p>Climb Kilimanjaro, run a Tanzania safari, or both. Talk to Nelson about your dates and what you want to shoot.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn-primary" style="font-size:1.05rem;padding:18px 40px">Plan My Trip &#x2192;</a>
        <a href="https://wa.me/255677917500" class="btn-wa" style="font-size:1rem" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Now</a>
      </div>
    </div>
  </div>
</section>

<div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="Photo viewer">
  <div class="lightbox-inner">
    <button class="lb-close" id="lb-close" aria-label="Close">&#x2715;</button>
    <button class="lb-prev" id="lb-prev" aria-label="Previous photo">&#x2039;</button>
    <button class="lb-next" id="lb-next" aria-label="Next photo">&#x203A;</button>
    <img id="lb-img" src="" alt="">
    <div class="lightbox-caption" id="lb-caption"></div>
  </div>
</div>

<script is:inline define:vars={ PHOTOS }>
(function() {
  const grid = document.getElementById('gal-grid');
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbCap = document.getElementById('lb-caption');
  const filters = document.querySelectorAll('.gal-filter');
  let currentIdx = 0;
  let visiblePhotos = PHOTOS.slice();
  let visibleIdxMap = PHOTOS.map((_, i) => i);
  const SUPPORTS_WEBP = (function() {
    try { return document.createElement('canvas').toDataURL('image/webp').indexOf('data:image/webp') === 0; } catch(e) { return false; }
  })();
  function show(idx) {
    if (idx < 0) idx = visiblePhotos.length - 1;
    if (idx >= visiblePhotos.length) idx = 0;
    currentIdx = idx;
    const p = visiblePhotos[idx];
    lbImg.src = SUPPORTS_WEBP ? '/images/gallery/' + p.slug.replace('.jpg','.webp') : '/images/gallery/' + p.slug;
    lbImg.alt = p.caption;
    lbCap.innerHTML = '<span class="cat">' + p.category + '</span>' + p.caption;
    lb.classList.add('open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function close() { lb.classList.remove('open'); lb.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
  function applyFilter(cat) {
    visiblePhotos = (cat === 'All') ? PHOTOS.slice() : PHOTOS.filter(p => p.category === cat);
    visibleIdxMap = PHOTOS.map((p, i) => (cat === 'All' || p.category === cat) ? i : -1).filter(i => i >= 0);
    document.querySelectorAll('.gal-card').forEach((card) => {
      const matches = (cat === 'All') || card.dataset.cat === cat;
      card.classList.toggle('hidden', !matches);
    });
  }
  grid.addEventListener('click', e => {
    const card = e.target.closest('.gal-card');
    if (!card) return;
    e.preventDefault();
    const idx = parseInt(card.dataset.idx, 10);
    const visibleI = visibleIdxMap.indexOf(idx);
    if (visibleI >= 0) show(visibleI);
  });
  document.getElementById('lb-close').addEventListener('click', close);
  document.getElementById('lb-prev').addEventListener('click', () => show(currentIdx - 1));
  document.getElementById('lb-next').addEventListener('click', () => show(currentIdx + 1));
  lb.addEventListener('click', e => { if (e.target === lb) close(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowLeft') show(currentIdx - 1);
    else if (e.key === 'ArrowRight') show(currentIdx + 1);
  });
  filters.forEach(btn => btn.addEventListener('click', () => {
    filters.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilter(btn.dataset.cat);
  }));
})();
</script>

</BaseLayout>
