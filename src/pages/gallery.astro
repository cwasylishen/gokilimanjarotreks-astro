s down the crater track.", "category": "Safari"}, {"slug": "safari-27-0919-002.jpg", "caption": "The Ngorongoro crater floor opens out under heavy cloud.", "category": "Safari"}, {"slug": "safari-27-0924-003.jpg", "caption": "A Thomson's gazelle pauses on the short grass.", "category": "Safari"}, {"slug": "safari-27-0934-004.jpg", "caption": "Pink flamingos spread across the crater's soda lake.", "category": "Safari"}, {"slug": "safari-27-0943-005.jpg", "caption": "Greater and lesser flamingos feed at the lake margin.", "category": "Safari"}, {"slug": "safari-27-0956-006.jpg", "caption": "A black-maned male yawns in the long grass.", "category": "Safari"}, {"slug": "safari-27-1003-007.jpg", "caption": "The same male settles in the green nettle, crater wall behind.", "category": "Safari"}, {"slug": "safari-27-1003-008.jpg", "caption": "Black-and-white study of a male lion on the crater floor.", "category": "Safari"}, {"slug": "safari-27-1008-009.jpg", "caption": "A Cape buffalo trails a cattle egret through the marsh.", "category": "Safari"}, {"slug": "safari-27-1208-010.jpg", "caption": "A Maasai giraffe browses the acacia at the crater rim.", "category": "Safari"}, {"slug": "safari-27-1208-011.jpg", "caption": "The same giraffe walks on through open woodland.", "category": "Safari"}, {"slug": "safari-27-1210-012.jpg", "caption": "A bull giraffe looks straight down the lens.", "category": "Safari"}, {"slug": "safari-27-1210-013.jpg", "caption": "A lone giraffe under the Ngorongoro highlands.", "category": "Safari"}, {"slug": "safari-27-1408-014.jpg", "caption": "Giraffe framed by twin acacias as the afternoon clouds build.", "category": "Safari"}, {"slug": "safari-27-1422-015.jpg", "caption": "A young lioness pauses in the tall savannah grass.", "category": "Safari"}, {"slug": "safari-27-1457-016.jpg", "caption": "An elephant family crosses the plains at last light.", "category": "Safari"}, {"slug": "safari-27-1457-017.jpg", "caption": "The herd keeps moving, bulls flanking the calves.", "category": "Safari"}, {"slug": "safari-27-1513-018.jpg", "caption": "A hippo pool baking in the late dry-season afternoon.", "category": "Safari"}, {"slug": "safari-27-1602-019.jpg", "caption": "Acacia silhouetted against the Serengeti sunset.", "category": "Safari"}, {"slug": "safari-28-0417-020.jpg", "caption": "Pre-dawn balloon drifting low over the Serengeti.", "category": "Safari"}, {"slug": "safari-28-0528-021.jpg", "caption": "Bucket-shower view from a tented camp at first light.", "category": "Camps"}, {"slug": "safari-28-0633-022.jpg", "caption": "A lone acacia under a mackerel sky.", "category": "Culture"}, {"slug": "safari-28-0649-023.jpg", "caption": "Male lion at rest in the morning grass.", "category": "Culture"}, {"slug": "safari-28-0652-024.jpg", "caption": "A father lion stands guard while two cubs nestle in the grass.", "category": "Culture"}, {"slug": "safari-28-0706-025.jpg", "caption": "Umbrella acacia under a pearl-grey dawn.", "category": "Culture"}, {"slug": "safari-28-0739-026.jpg", "caption": "A Coke's hartebeest watches from the open plain.", "category": "Culture"}, {"slug": "safari-28-0745-027.jpg", "caption": "A pod of hippos crowds the river shallows.", "category": "Safari"}, {"slug": "safari-28-0759-028.jpg", "caption": "Skeletal acacia against the morning sky.", "category": "Safari"}, {"slug": "safari-28-0803-029.jpg", "caption": "Two olive baboons survey the plain from a dead tree.", "category": "Safari"}, {"slug": "safari-28-0812-030.jpg", "caption": "A herd of topi grazes the open grassland.", "category": "Safari"}, {"slug": "safari-28-0822-031.jpg", "caption": "A weathered tree stands alone on the Serengeti plain.", "category": "Safari"}, {"slug": "safari-28-0824-032.jpg", "caption": "A single acacia and one perfect cloud.", "category": "Safari"}, {"slug": "safari-28-0848-033.jpg", "caption": "A rain shaft streaks down across the Serengeti horizon.", "category": "Safari"}, {"slug": "safari-28-1125-034.jpg", "caption": "Zebras and cattle egrets share the short grass.", "category": "Safari"}, {"slug": "safari-28-1135-035.jpg", "caption": "A spotted hyena patrols the green crater floor.", "category": "Safari"}, {"slug": "safari-28-1137-036.jpg", "caption": "The hyena stops to take stock of the truck.", "category": "Safari"}, {"slug": "safari-28-1138-037.jpg", "caption": "Spotted hyena in the foreground, zebras grazing behind.", "category": "Safari"}, {"slug": "safari-28-1218-038.jpg", "caption": "A male and female ostrich foraging together.", "category": "Safari"}, {"slug": "safari-28-1331-039.jpg", "caption": "Panorama from the Ngorongoro rim looking down to the crater lake.", "category": "Safari"}, {"slug": "safari-29-0754-040.jpg", "caption": "A Maasai family hut, close up.", "category": "Culture"}, {"slug": "safari-29-0817-041.jpg", "caption": "Maasai children at a village classroom, mid-lesson.", "category": "Culture"}, {"slug": "safari-29-1054-042.jpg", "caption": "A bend in the Tarangire River from the escarpment.", "category": "Safari"}, {"slug": "safari-ff-PXL-043.jpg", "caption": "Crater male, mouth open mid-yawn.", "category": "Safari"}];

const CATEGORIES = ["All", "Routes", "Crew", "Camps", "Mountains", "Glacier", "Safari", "Culture", "Day Trips", "Climbers"];

const ldImages = PHOTOS.map(p => ({
  "@type": "ImageObject",
  "contentUrl": `https://gokilimanjarotreks.com/images/gallery/${p.slug}`,
  "description": p.caption,
  "creditText": "Go Kilimanjaro Treks"
}));

const galleryLd = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  "url": "https://gokilimanjarotreks.com/gallery",
  "name": "Go Kilimanjaro Treks Photo Gallery",
  "description": "Original photography from Mount Kilimanjaro climbs and northern Tanzania safaris with Go Kilimanjaro Treks.",
  "image": ldImages,
  "publisher": {"@id": "https://gokilimanjarotreks.com/#organization"}
};
---

<BaseLayout
  title="Photo Gallery: Kilimanjaro Climbs & Tanzania Safaris | Go Kilimanjaro Treks"
  description="Original photography from Mount Kilimanjaro climbs and northern Tanzania safaris. Routes, camps, the mountain crew, glaciers, and wildlife."
  ogImage="https://gokilimanjarotreks.com/images/gallery/summit-celebration-group.jpg"
  ogImageAlt="Climbers celebrating at altitude on Mount Kilimanjaro"
  schemas={[galleryLd]}
>

<section class="gal-hero">
  <div class="container">
    <span class="eyebrow">From the Mountain</span>
    <h1>The <em>Gallery.</em></h1>
    <p>Original photography from Mount Kilimanjaro climbs and northern Tanzania safaris. Tap any photo to view larger.</p>
  </div>
</section>

<section class="gal-controls">
  <div class="container">
    <div class="gal-filters" role="tablist" aria-label="Filter photos by category">
      {CATEGORIES.map((cat) => (
        <button class={"gal-filter" + (cat === "All" ? " active" : "")} data-cat={cat}>{cat}</button>
      ))}
    </div>
  </div>
</section>

<section class="gal-grid-wrap">
  <div class="container">
    <div class="gal-grid" id="gal-grid">
      {PHOTOS.map((p, i) => (
        <a class="gal-card" data-cat={p.category} data-idx={i} href={`/images/gallery/${p.slug}`} aria-label={`View larger: ${p.caption}`}>
          <picture>
            <source type="image/webp" srcset={`/images/gallery/${p.slug.replace('.jpg','.webp')}`} />
            <img src={`/images/gallery/${p.slug}`} alt={p.caption} loading="lazy" />
          </picture>
          <div class="gal-meta"><span class="gal-cat">{p.category}</span>{p.caption}</div>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <div class="reveal">
      <h2>Make Your Own <em>Photos.</em></h2>
      <p>Climb Kilimanjaro, run a Tanzania safari, or both. Talk to Nelson about your dates and what you want to shoot.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn-primary" style="font-size:1.05rem;padding:18px 40px">Plan My Trip &#x2192;</a>
        <a href="https://wa.me/255677917500" class="btn-wa" style="font-size:1rem" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Now</a>
      </div>
    </div>
  </div>
</section>

<div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="Photo viewer">
  <div class="lightbox-inner">
    <button class="lb-close" id="lb-close" aria-label="Close">&#x2715;</button>
    <button class="lb-prev" id="lb-prev" aria-label="Previous photo">&#x2039;</button>
    <button class="lb-next" id="lb-next" aria-label="Next photo">&#x203A;</button>
    <img id="lb-img" src="" alt="">
    <div class="lightbox-caption" id="lb-caption"></div>
  </div>
</div>

<script is:inline define:vars={ PHOTOS }>
(function() {
  const grid = document.getElementById('gal-grid');
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbCap = document.getElementById('lb-caption');
  const filters = document.querySelectorAll('.gal-filter');
  let currentIdx = 0;
  let visiblePhotos = PHOTOS.slice();
  let visibleIdxMap = PHOTOS.map((_, i) => i);
  const SUPPORTS_WEBP = (function() {
    try { return document.createElement('canvas').toDataURL('image/webp').indexOf('data:image/webp') === 0; } catch(e) { return false; }
  })();
  function show(idx) {
    if (idx < 0) idx = visiblePhotos.length - 1;
    if (idx >= visiblePhotos.length) idx = 0;
    currentIdx = idx;
    const p = visiblePhotos[idx];
    lbImg.src = SUPPORTS_WEBP ? '/images/gallery/' + p.slug.replace('.jpg','.webp') : '/images/gallery/' + p.slug;
    lbImg.alt = p.caption;
    lbCap.innerHTML = '<span class="cat">' + p.category + '</span>' + p.caption;
    lb.classList.add('open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function close() { lb.classList.remove('open'); lb.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
  function applyFilter(cat) {
    visiblePhotos = (cat === 'All') ? PHOTOS.slice() : PHOTOS.filter(p => p.category === cat);
    visibleIdxMap = PHOTOS.map((p, i) => (cat === 'All' || p.category === cat) ? i : -1).filter(i => i >= 0);
    document.querySelectorAll('.gal-card').forEach((card) => {
      const matches = (cat === 'All') || card.dataset.cat === cat;
      card.classList.toggle('hidden', !matches);
    });
  }
  grid.addEventListener('click', e => {
    const card = e.target.closest('.gal-card');
    if (!card) return;
    e.preventDefault();
    const idx = parseInt(card.dataset.idx, 10);
    const visibleI = visibleIdxMap.indexOf(idx);
    if (visibleI >= 0) show(visibleI);
  });
  document.getElementById('lb-close').addEventListener('click', close);
  document.getElementById('lb-prev').addEventListener('click', () => show(currentIdx - 1));
  document.getElementById('lb-next').addEventListener('click', () => show(currentIdx + 1));
  lb.addEventListener('click', e => { if (e.target === lb) close(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowLeft') show(currentIdx - 1);
    else if (e.key === 'ArrowRight') show(currentIdx + 1);
  });
  filters.forEach(btn => btn.addEventListener('click', () => {
    filters.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilter(btn.dataset.cat);
  }));
})();
</script>

</BaseLayout>
