<BaseLayout
  title="Photo Gallery: Kilimanjaro Climbs &amp; Tanzania Safaris | Go Kilimanjaro Treks"
  description="Original photography from Mount Kilimanjaro climbs and northern Tanzania safaris. Routes, camps, the mountain crew, glaciers, and wildlife. Photographed by Nelson Mushi and Go Kilimanjaro Treks climbers."
  ogImage="https://gokilimanjarotreks.com/images/gallery/summit-celebration-group.jpg"
  ogImageAlt="Climbers celebrating at altitude on Mount Kilimanjaro"
  schemas={schemas}
>
  <main>
<section class="gal-hero">
  <div class="container">
    <span class="eyebrow">From the Mountain</span>
    <h1>The <em>Gallery.</em></h1>
    <p>Original photography from Mount Kilimanjaro climbs and northern Tanzania safaris. Routes, camps, the mountain crew, glaciers, and wildlife. Tap any photo to view larger.</p>
  </div>
</section>

<section class="gal-controls">
  <div class="container">
    <div class="gal-filters" role="tablist" aria-label="Filter photos by category">
      <button class="gal-filter active" data-cat="All">All</button>
      <button class="gal-filter" data-cat="Routes">Routes</button>
      <button class="gal-filter" data-cat="Crew">Crew</button>
      <button class="gal-filter" data-cat="Camps">Camps</button>
      <button class="gal-filter" data-cat="Mountains">Mountains</button>
      <button class="gal-filter" data-cat="Glacier">Glacier</button>
      <button class="gal-filter" data-cat="Safari">Safari</button>
      <button class="gal-filter" data-cat="Day Trips">Day Trips</button>
      <button class="gal-filter" data-cat="Climbers">Climbers</button>
    </div>
  </div>
</section>

