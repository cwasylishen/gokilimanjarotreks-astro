import BaseLayout from '../layouts/BaseLayout.astro';

const PHOTOS = [{"slug": "machame-rainforest-ascent.jpg", "caption": "Climbers ascending through the lower montane forest on the Machame Route.", "category": "Routes"}, {"slug": "summit-celebration-group.jpg", "caption": "Climbers celebrating at altitude on a Go Kilimanjaro Treks expedition.", "category": "Climbers"}, {"slug": "serengeti-elephant-herd.jpg", "caption": "Elephant herd under the acacia trees in the Serengeti.", "category": "Safari"}, {"slug": "serengeti-lions.jpg", "caption": "Lion pair on the open Serengeti plains.", "category": "Safari"}, {"slug": "kibo-summit-approach.jpg", "caption": "Climbers approaching the snow line on the Kibo summit cone.", "category": "Routes"}, {"slug": "kilimanjaro-glacier-wall.jpg", "caption": "Walking past the glacier wall on the summit, above the cloud sea.", "category": "Glacier"}, {"slug": "mount-meru-ash-cone.jpg", "caption": "Mount Meru's ash cone in late golden light.", "category": "Mountains"}, {"slug": "barranco-wall-scramble.jpg", "caption": "Climbers on the Barranco Wall scramble, Southern Circuit.", "category": "Routes"}, {"slug": "kilimanjaro-sunset-pink-sky.jpg", "caption": "Mount Kilimanjaro at sunset in the pink hour above the cloud line.", "category": "Mountains"}, {"slug": "porter-walking-toward-kibo.jpg", "caption": "A porter walking the trail with the snow-capped Kibo summit ahead.", "category": "Crew"}, {"slug": "porter-load-on-marangu.jpg", "caption": "A porter carrying the team's load on the upper Marangu route, Kibo ahead.", "category": "Crew"}, {"slug": "machame-misty-forest-descent.jpg", "caption": "Climbers in the misty rainforest section of the lower mountain.", "category": "Routes"}, {"slug": "serengeti-balloon-migration.jpg", "caption": "Hot air balloon drifting over the Great Migration in the Serengeti.", "category": "Safari"}, {"slug": "mandara-hut-triangular-roofs.jpg", "caption": "The A-frame Mandara Hut cluster on the Marangu Route.", "category": "Camps"}, {"slug": "marangu-zebra-rocks.jp