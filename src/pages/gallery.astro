"images/gallery/ngorongoro-wildebeest-zebra.webp","caption":"Wildebeest and zebra on the Ngorongoro Crater floor.","category":"Safari"},{"jpg":"images/gallery/marangu-mawenzi-trail.jpg","webp":"images/gallery/marangu-mawenzi-trail.webp","caption":"The trail toward Mawenzi Peak on the Marangu Route.","category":"Routes"},{"jpg":"images/gallery/summit-zone-scree-walk.jpg","webp":"images/gallery/summit-zone-scree-walk.webp","caption":"Crossing the summit-zone scree slopes high on Kilimanjaro.","category":"Routes"},{"jpg":"images/gallery/above-the-clouds-glacier.jpg","webp":"images/gallery/above-the-clouds-glacier.webp","caption":"Climbers at altitude above the cloud sea, beside a glacier wall.","category":"Glacier"},{"jpg":"images/gallery/barranco-wall-scramble-close.jpg","webp":"images/gallery/barranco-wall-scramble-close.webp","caption":"Detail on the Barranco Wall climb, Southern Circuit.","category":"Routes"},{"jpg":"images/gallery/summit-sunrise-mawenzi-flare.jpg","webp":"images/gallery/summit-sunrise-mawenzi-flare.webp","caption":"Sunrise over Mawenzi from the summit zone, sunburst over the cloud sea.","category":"Mountains"},{"jpg":"images/gallery/barranco-camp-tent.jpg","webp":"images/gallery/barranco-camp-tent.webp","caption":"A tent at Barranco Camp beneath the dark Barranco Wall.","category":"Camps"},{"jpg":"images/gallery/kilimanjaro-dawn-pink-flowers.jpg","webp":"images/gallery/kilimanjaro-dawn-pink-flowers.webp","caption":"Mt Kilimanjaro at dawn, framed by wildflowers on the lower slopes.","category":"Mountains"},{"jpg":"images/gallery/summit-snow-plateau-dawn.jpg","webp":"images/gallery/summit-snow-plateau-dawn.webp","caption":"Dawn on the summit snow plateau, Mawenzi rising from the cloud sea.","category":"Mountains"},{"jpg":"images/gallery/uhuru-sunrise-mawenzi-flare.jpg","webp":"images/gallery/uhuru-sunrise-mawenzi-flare.webp","caption":"Sunrise with Mawenzi backlit and a wide lens flare across the cloud sea.","category":"Mountains"},{"jpg":"images/gallery/lone-tree-sunset-meru.jpg","webp":"images/gallery/lone-tree-sunset-meru.webp","caption":"Lone tree silhouette above the cloud line at sunset, Mt Meru in the distance.","category":"Mountains"},{"jpg":"images/gallery/mawenzi-pink-dawn-silhouette.jpg","webp":"images/gallery/mawenzi-pink-dawn-silhouette.webp","caption":"Mawenzi Peak silhouette under a pink dawn sky from the summit zone.","category":"Mountains"},{"jpg":"images/gallery/tree-bird-mount-meru-dusk.jpg","webp":"images/gallery/tree-bird-mount-meru-dusk.webp","caption":"A lone tree and a bird in flight against the pink dusk, Mt Meru distant.","category":"Mountains"},{"jpg":"images/gallery/serengeti-lion-portrait.jpg","webp":"images/gallery/serengeti-lion-portrait.webp","caption":"A male lion in the tall grass of the Serengeti, looking straight at the camera.","category":"Safari"},{"jpg":"images/gallery/ngorongoro-lion-crater-walls.jpg","webp":"images/gallery/ngorongoro-lion-crater-walls.webp","caption":"A male lion standing on the Ngorongoro Crater floor with the crater walls behind.","category":"Safari"},{"jpg":"images/gallery/serengeti-lion-pair.jpg","webp":"images/gallery/serengeti-lion-pair.webp","caption":"A pair of lions moving together through the Serengeti grass.","category":"Safari"},{"jpg":"images/gallery/serengeti-zebra-mother-foal.jpg","webp":"images/gallery/serengeti-zebra-mother-foal.webp","caption":"A zebra mother and her foal close in the grass.","category":"Safari"},{"jpg":"images/gallery/wildebeest-zebra-graze-foothills.jpg","webp":"images/gallery/wildebeest-zebra-graze-foothills.webp","caption":"Wildebeest and zebra grazing together with the highland foothills behind.","category":"Safari"},{"jpg":"images/gallery/maasai-women-traditional-dress.jpg","webp":"images/gallery/maasai-women-traditional-dress.webp","caption":"Maasai women in traditional dress and beaded headpieces.","category":"Culture"},{"jpg":"images/gallery/maasai-cooking-with-visitors.jpg","webp":"images/gallery/maasai-cooking-with-visitors.webp","caption":"Cooking together with a Maasai family during a cultural visit.","category":"Culture"},{"jpg":"images/gallery/maasai-cultural-welcome.jpg","webp":"images/gallery/maasai-cultural-welcome.webp","caption":"A Maasai welcome circle with visitors and community members in shukas.","category":"Culture"}];
  const grid = document.getElementById('gal-grid');
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lb-img');
  const lbCap = document.getElementById('lb-caption');
  const filters = document.querySelectorAll('.gal-filter');
  let currentIdx = 0;
  let visiblePhotos = PHOTOS.slice();
  let visibleIdxMap = PHOTOS.map((_, i) => i);

  const SUPPORTS_WEBP = (function(){
    try { return document.createElement('canvas').toDataURL('image/webp').indexOf('data:image/webp') === 0; }
    catch(e) { return false; }
  })();
  function show(idx) {
    if (idx < 0) idx = visiblePhotos.length - 1;
    if (idx >= visiblePhotos.length) idx = 0;
    currentIdx = idx;
    const p = visiblePhotos[idx];
    lbImg.src = SUPPORTS_WEBP ? p.webp : p.jpg;
    lbImg.alt = p.caption;
    lbCap.innerHTML = '<span class="cat">' + p.category + '</span>' + p.caption;
    lb.classList.add('open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    lb.classList.remove('open');
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }
  function applyFilter(cat) {
    visiblePhotos = (cat === 'All') ? PHOTOS.slice() : PHOTOS.filter(p => p.category === cat);
    visibleIdxMap = PHOTOS.map((p, i) => (cat === 'All' || p.category === cat) ? i : -1).filter(i => i >= 0);
    document.querySelectorAll('.gal-card').forEach((card, i) => {
      const matches = (cat === 'All') || card.dataset.cat === cat;
      card.classList.toggle('hidden', !matches);
    });
  }

  grid.addEventListener('click', e => {
    const card = e.target.closest('.gal-card');
    if (!card) return;
    e.preventDefault();
    const idx = parseInt(card.dataset.idx, 10);
    const visibleI = visibleIdxMap.indexOf(idx);
    if (visibleI >= 0) show(visibleI);
  });
  document.getElementById('lb-close').addEventListener('click', close);
  document.getElementById('lb-prev').addEventListener('click', () => show(currentIdx - 1));
  document.getElementById('lb-next').addEventListener('click', () => show(currentIdx + 1));
  lb.addEventListener('click', e => { if (e.target === lb || e.target === lb.firstElementChild) close(); });
  document.addEventListener('keydown', e => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') close();
    else if (e.key === 'ArrowLeft') show(currentIdx - 1);
    else if (e.key === 'ArrowRight') show(currentIdx + 1);
  });
  filters.forEach(btn => btn.addEventListener('click', () => {
    filters.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    applyFilter(btn.dataset.cat);
  }));
})();
</script>

