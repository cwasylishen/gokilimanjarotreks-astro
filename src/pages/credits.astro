<BaseLayout
  title="Image Credits | Go Kilimanjaro Treks"
  description="Attribution for photographs used on the Go Kilimanjaro Treks website. Several images are used under Creative Commons licenses from Wikimedia Commons."
  ogImage="https://gokilimanjarotreks.com/images/og-home.jpg"
  ogImageAlt="Go Kilimanjaro Treks"
  schemas={schemas}
