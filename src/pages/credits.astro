---
import BaseLayout from '../layouts/BaseLayout.astro';
const schemas = [{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://gokilimanjarotreks.com/"},{"@type":"ListItem","position":2,"name":"Image Credits","item":"https://gokilimanjarotreks.com/credits.html"}],"dateModified":"2026-05-26"}];
