---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schemas = [{"@context": "https://schema.org", "@type": "TouristTrip", "name": "Horseback Riding", "description": "A horseback riding day trip on a wildlife estate near Arusha, riding quietly alongside zebra and antelope under Mount Meru. All levels welcome.", "provider": {"@id": "https://gokilimanjarotreks.com/#organization"}, "touristType": "Day-trip traveller", "url": "https://gokilimanjarotreks.com/daytrips/horseback-riding", "duration": "P1D", "offers": {"@type": "Offer", "price": "120", "priceCurrency": "USD", "url": "https://gokilimanjarotreks.com/daytrips/horseback-riding", "availability": "https://schema.org/InStock", "description": "Starting price per person"}}, {"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://gokilimanjarotreks.com/"}, {"@type": "ListItem", "position": 2, "name": "Day Trips", "item": "https://gokilimanjarotreks.com/daytrips"}, {"@type": "ListItem", "position": 3, "name": "Horseback Riding", "item": "https://gokilimanjarotreks.com/daytrips/horseback-riding"}]}];
---

<BaseLayout
  title="Horseback Safari Near Arusha | Go Kilimanjaro Treks"
  description="A horseback riding day trip on a wildlife estate near Arusha, riding quietly alongside zebra and antelope under Mount Meru. All levels welcome."
  ogImage="https://gokilimanjarotreks.com/images/daytrip-horseback.jpg"
  ogImageAlt="Riders on horseback crossing an open grassland"
  schemas={schemas}
>

<section class="page-hero">
  <img src="/images/daytrip-horseback.jpg" alt="" aria-hidden="true" loading="eager" fetchpriority="high" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;z-index:0;opacity:0.55" />
  <div aria-hidden="true" style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(2,6,14,0.88) 0%,rgba(2,6,14,0.82) 40%,rgba(2,6,14,0.55) 65%,rgba(2,6,14,0.15) 100%);z-index:1"></div>
  <div class="container">
    <span class="page-hero-eyebrow">Tanzania Day Trip</span>
    <h1>Horseback Riding</h1>
    <p>Experience the freedom of the African bush from a completely unique perspective. Located on an exclusive wildlife estate just outside Arusha town, this horseback riding day trip allows you to ride gently alongside plains game, moving quietly through scenery without the noise and disruption of a traditional safari vehicle.</p>
    <div class="hero-ctas">
      <a href="/contact" class="btn-primary">Request a Quote &#x2192;</a>
      <a href="https://wa.me/255677917500" class="btn-ghost" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Nelson</a>
    </div>
  </div>
</section>

<section class="section-white">
  <div class="container" style="max-width:820px">
    <p style="font-size:1.15rem;color:var(--amber-cta);font-weight:700;margin:30px 0 18px">From $120 per person</p>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">Highlights</h2>
    <ul style="padding-left:22px;margin-bottom:8px">
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Ride horses side-by-side with wild zebras, wildebeests, and antelopes.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Enjoy trails tailored perfectly to your riding level, from beginners to advanced riders.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Take in a peaceful, eco-friendly outdoor adventure under the shadow of Mount Meru.</li>
    </ul>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">A Day on This Trip</h2>
    <ol style="padding-left:22px;margin-bottom:8px">
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">08:00 AM / 02:00 PM: Pick up from your Arusha hotel and transfer to the equestrian center.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">08:45 AM: Meet your riding guide, get fitted for your helmet, and be matched with a horse suited to your experience level.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">09:00 AM: Spend two hours riding across open tracks, viewing wildlife that remains completely relaxed around the horses.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">11:15 AM: Return to the stables for a light snack, coffee, or cold refreshments.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">12:00 PM: Head back to your hotel or onward destination.</li>
    </ol>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">What is Included</h2>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Horse rental, professional riding guide, riding safety gear (helmets, chaps), estate entry fees, transfers, and light refreshments.</p>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">What is Not Included</h2>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Full meals, personal riding attire (long pants and closed shoes required), and tips.</p>
    <p style="font-size:.92rem;color:var(--muted);line-height:1.7;margin-top:18px">Every day trip is private and fully customisable. Prices vary with group size and season, so message Nelson for an exact quote for your dates.</p>
  </div>
</section>

<section class="section-tinted">
  <div class="container" style="max-width:900px;text-align:center">
    <h2 style="font-family:var(--font-display);font-size:clamp(1.5rem,3vw,2rem);font-weight:700;color:var(--ink-2);margin-bottom:8px">More Tanzania Day Trips</h2>
    <p style="color:var(--muted);margin-bottom:22px">Pair this with another single-day adventure from Moshi or Arusha.</p>
    <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center">
<a href="/daytrips/tarangire" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Tarangire Safari Tour</a>
<a href="/daytrips/materuni-waterfall-coffee" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Materuni Waterfall and Coffee Farm Tour</a>
<a href="/daytrips/arusha-national-park" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Arusha Safari</a>
<a href="/daytrips/ol-doinyo-lengai" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Ol Doinyo Lengai</a>
<a href="/daytrips/kilimanjaro-helicopter-tour" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Kilimanjaro Helicopter Tour</a>
<a href="/daytrips/lake-chala" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Lake Chala</a>
<a href="/daytrips/ndarakwai-ranch" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Ndarakwai Ranch</a>
<a href="/daytrips/chemka-hot-springs" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Chemka Hot Springs</a>
<a href="/daytrips/kilimanjaro-day-hike" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Mount Kilimanjaro Day Hikes</a>
<a href="/daytrips/arusha-shopping-tour" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Arusha Shopping Tour</a>
<a href="/daytrips/ngorongoro" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Ngorongoro Crater Day Trip</a>
    </div>
    <p style="margin-top:24px"><a href="/daytrips" style="color:var(--amber-cta);font-weight:600">See all day trips &#x2192;</a></p>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2>Ready to <em>Book This Day Trip</em>?</h2>
    <p>Talk to Nelson about your dates and the rest of your time in Tanzania. He responds personally within 24 hours.</p>
    <div class="cta-actions">
      <a href="/contact" class="btn-primary" style="font-size:1.05rem;padding:18px 40px">Request a Quote &#x2192;</a>
      <a href="https://wa.me/255677917500" class="btn-wa" style="font-size:1rem" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Now</a>
    </div>
  </div>
</section>

</BaseLayout>
