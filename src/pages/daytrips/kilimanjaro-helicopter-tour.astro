---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schemas = [{"@context": "https://schema.org", "@type": "TouristTrip", "name": "Kilimanjaro Helicopter Tour", "description": "A scenic helicopter flight over Mount Kilimanjaro's summit, glaciers and craters, with hotel transfers from Arusha. See the Roof of Africa from the air.", "provider": {"@id": "https://gokilimanjarotreks.com/#organization"}, "touristType": "Day-trip traveller", "url": "https://gokilimanjarotreks.com/daytrips/kilimanjaro-helicopter-tour", "duration": "P1D", "offers": {"@type": "Offer", "price": "3500", "priceCurrency": "USD", "url": "https://gokilimanjarotreks.com/daytrips/kilimanjaro-helicopter-tour", "availability": "https://schema.org/InStock", "description": "Starting price per person"}}, {"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://gokilimanjarotreks.com/"}, {"@type": "ListItem", "position": 2, "name": "Day Trips", "item": "https://gokilimanjarotreks.com/daytrips"}, {"@type": "ListItem", "position": 3, "name": "Kilimanjaro Helicopter Tour", "item": "https://gokilimanjarotreks.com/daytrips/kilimanjaro-helicopter-tour"}]}];
---

<BaseLayout
  title="Kilimanjaro Helicopter Tour | Go Kilimanjaro Treks"
  description="A scenic helicopter flight over Mount Kilimanjaro's summit, glaciers and craters, with hotel transfers from Arusha. See the Roof of Africa from the air."
  ogImage="https://gokilimanjarotreks.com/images/daytrip-helicopter.jpg"
  ogImageAlt="Aerial view of Mount Kilimanjaro from above the clouds"
  schemas={schemas}
>

<section class="page-hero">
  <img src="/images/daytrip-helicopter.jpg" alt="" aria-hidden="true" loading="eager" fetchpriority="high" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;z-index:0;opacity:0.55" />
  <div aria-hidden="true" style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(2,6,14,0.88) 0%,rgba(2,6,14,0.82) 40%,rgba(2,6,14,0.55) 65%,rgba(2,6,14,0.15) 100%);z-index:1"></div>
  <div class="container">
    <span class="page-hero-eyebrow">Tanzania Day Trip</span>
    <h1>Kilimanjaro Helicopter Tour</h1>
    <p>Experience the ultimate luxury adventure and skip the grueling multi-day trek to see the rooftop of Africa. This exclusive scenic flight lifts you high above the clouds, providing a thrilling, birds-eye perspective of Mount Kilimanjaro&#39;s majestic snow-capped peaks, dramatic volcanic craters, and ancient glacial walls.</p>
    <div class="hero-ctas">
      <a href="/contact" class="btn-primary">Request a Quote &#x2192;</a>
      <a href="https://wa.me/255677917500" class="btn-ghost" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Nelson</a>
    </div>
  </div>
</section>

<section class="section-white">
  <div class="container" style="max-width:820px">
    <p style="font-size:1.15rem;color:var(--amber-cta);font-weight:700;margin:30px 0 18px">From $3,500 per person</p>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">Highlights</h2>
    <ul style="padding-left:22px;margin-bottom:8px">
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Soar directly past the iconic, snow-dusted Uhuru Peak and the jagged crags of Mawenzi.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Enjoy unmatched aerial photography opportunities of East Africa&#39;s most famous geographic landmark.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Experience a premium, comfortable journey with a professional pilot providing live commentary.</li>
    </ul>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">A Day on This Trip</h2>
    <ol style="padding-left:22px;margin-bottom:8px">
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">06:30 AM: Morning pick-up from your hotel and transfer to the Arusha Airport or assigned helipad.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">07:15 AM: Meet your pilot, review safety protocols, and map out the flight path.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">07:30 AM: Lift off and fly towards the mountain as the morning light hits the plains.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">08:00 AM: Spend unforgettable minutes soaring around the Kibo caldera, ice fields, and dramatic alpine desert zones.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">08:45 AM: Fly back over the lush montane forest belt and touch down safely.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">09:30 AM: Transfer back to your hotel in time for a late breakfast.</li>
    </ol>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">What is Included</h2>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">VIP private helicopter flight, fuel, professional pilot, airport/landing fees, hotel transfers, and a celebratory glass of champagne or juice upon landing.</p>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">What is Not Included</h2>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Gratuities for the flight crew and international travel insurance.</p>
    <p style="font-size:.92rem;color:var(--muted);line-height:1.7;margin-top:18px">Every day trip is private and fully customisable. Prices vary with group size and season, so message Nelson for an exact quote for your dates.</p>
  </div>
</section>

<section class="section-tinted">
  <div class="container" style="max-width:900px;text-align:center">
    <h2 style="font-family:var(--font-display);font-size:clamp(1.5rem,3vw,2rem);font-weight:700;color:var(--ink-2);margin-bottom:8px">More Tanzania Day Trips</h2>
    <p style="color:var(--muted);margin-bottom:22px">Pair this with another single-day adventure from Moshi or Arusha.</p>
    <div style="display:flex;flex-wrap:wrap;gap:10px;justify-content:center">
<a href="/daytrips/tarangire" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Tarangire Safari Tour</a>
<a href="/daytrips/materuni-waterfall-coffee" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Materuni Waterfall and Coffee Farm Tour</a>
<a href="/daytrips/arusha-national-park" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Arusha Safari</a>
<a href="/daytrips/ol-doinyo-lengai" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Ol Doinyo Lengai</a>
<a href="/daytrips/lake-chala" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Lake Chala</a>
<a href="/daytrips/ndarakwai-ranch" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Ndarakwai Ranch</a>
<a href="/daytrips/chemka-hot-springs" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Chemka Hot Springs</a>
<a href="/daytrips/kilimanjaro-day-hike" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Mount Kilimanjaro Day Hikes</a>
<a href="/daytrips/horseback-riding" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Horseback Riding</a>
<a href="/daytrips/arusha-shopping-tour" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Arusha Shopping Tour</a>
<a href="/daytrips/ngorongoro" style="display:inline-block;padding:8px 16px;border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;color:var(--ink-2);text-decoration:none;font-weight:600">Ngorongoro Crater Day Trip</a>
    </div>
    <p style="margin-top:24px"><a href="/daytrips" style="color:var(--amber-cta);font-weight:600">See all day trips &#x2192;</a></p>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2>Ready to <em>Book This Day Trip</em>?</h2>
    <p>Talk to Nelson about your dates and the rest of your time in Tanzania. He responds personally within 24 hours.</p>
    <div class="cta-actions">
      <a href="/contact" class="btn-primary" style="font-size:1.05rem;padding:18px 40px">Request a Quote &#x2192;</a>
      <a href="https://wa.me/255677917500" class="btn-wa" style="font-size:1rem" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Now</a>
    </div>
  </div>
</section>

</BaseLayout>
