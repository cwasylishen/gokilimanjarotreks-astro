---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schemas = [{
  "@context":"https://schema.org","@type":"TouristTrip",
  "name":"Tarangire National Park Day Trip",
  "description":"Tanzania day trip safari to Tarangire National Park, famous for its baobab trees and large elephant herds.",
  "provider":{"@id":"https://gokilimanjarotreks.com/#organization"},
  "touristType":"Day-trip safari traveller",
  "url":"https://gokilimanjarotreks.com/daytrips/tarangire",
  "duration":"P1D"
}];
---

<BaseLayout
  title="Tarangire National Park Day Trip | Go Kilimanjaro Treks"
  description="Tanzania day trip safari to Tarangire National Park, famous for its baobab trees and large elephant herds."
  ogImage="https://gokilimanjarotreks.com/images/gallery/serengeti-elephant-herd.jpg"
  ogImageAlt="Elephant herd in Tanzania"
  schemas={schemas}
>

<section class="page-hero">
  <img src="/images/gallery/serengeti-elephant-herd.jpg" alt="" aria-hidden="true" loading="eager" fetchpriority="high" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 35%;z-index:0;opacity:0.55" />
  <div aria-hidden="true" style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(2,6,14,0.88) 0%,rgba(2,6,14,0.82) 40%,rgba(2,6,14,0.55) 65%,rgba(2,6,14,0.15) 100%);z-index:1"></div>
  <div class="container">
    <span class="page-hero-eyebrow">Tanzania Day Trip</span>
    <h1>Tarangire National Park Day Trip.</h1>
    <p>Tanzania day trip safari to Tarangire National Park, famous for its baobab trees and large elephant herds.</p>
    <div class="hero-ctas">
      <a href="/contact" class="btn-primary">Request a Quote &#x2192;</a>
      <a href="https://wa.me/255677917500" class="btn-ghost" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Nelson</a>
    </div>
  </div>
</section>

<section class="section-white">
  <div class="container" style="max-width:820px">
    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">DAY TRIP TO TARANGIRE NATIONAL PARK</h2>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Price Starts From 360 USD.</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Discover the beauty of Tarangire National Park, one of Tanzania's most remarkable wildlife destinations. Known for its large elephant herds, iconic baobab trees, and diverse wildlife, Tarangire offers an authentic safari experience in a stunning natural setting.</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Enjoy a full-day game drive through the park's varied landscapes, including open savannahs, acacia woodlands, and the Tarangire River, which attracts a wide range of animals throughout the year. Wildlife sightings may include elephants, lions, leopards, giraffes, zebras, wildebeests, buffaloes, impalas, warthogs, and many other species. The park is also a paradise for bird lovers, with over 500 recorded bird species.</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">A picnic lunch will be served at one of the park's scenic picnic sites, allowing you to relax and enjoy the surrounding wilderness before continuing your afternoon game drive.</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Tarangire is especially famous for its ancient baobab trees and exceptional elephant population, making it one of the most unique and rewarding safari destinations in Northern Tanzania.</p>
<h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">Price includes</h2>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Park entrance fees</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Professional English-speaking safari guide</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Private 4x4 safari vehicle with pop-up roof</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Picnic lunch</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Bottled drinking water</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Government taxes and VAT</p>
<h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">Not Included</h2>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• International flights</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Travel insurance</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Personal expenses</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Alcoholic and soft drinks</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Tips and gratuities</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Items of a personal nature</p>
<p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">END.</p>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2>Ready to <em>Book This Day Trip</em>?</h2>
    <p>Talk to Nelson about your dates and the rest of your time in Tanzania. He responds personally within 24 hours.</p>
    <div class="cta-actions">
      <a href="/contact" class="btn-primary" style="font-size:1.05rem;padding:18px 40px">Request a Quote &#x2192;</a>
      <a href="https://wa.me/255677917500" class="btn-wa" style="font-size:1rem" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Now</a>
    </div>
  </div>
</section>

</BaseLayout>
