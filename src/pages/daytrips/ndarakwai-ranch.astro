---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schemas = [{"@context": "https://schema.org", "@type": "TouristTrip", "name": "Ndarakwai Ranch", "description": "A walking safari on the private 11,000-acre Ndarakwai conservation ranch on the western slopes of Kilimanjaro, supporting Maasai community conservation.", "provider": {"@id": "https://gokilimanjarotreks.com/#organization"}, "touristType": "Day-trip traveller", "url": "https://gokilimanjarotreks.com/daytrips/ndarakwai-ranch", "duration": "P1D", "offers": {"@type": "Offer", "price": "191", "priceCurrency": "USD", "url": "https://gokilimanjarotreks.com/daytrips/ndarakwai-ranch", "availability": "https://schema.org/InStock", "description": "Starting price per person"}}, {"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://gokilimanjarotreks.com/"}, {"@type": "ListItem", "position": 2, "name": "Day Trips", "item": "https://gokilimanjarotreks.com/daytrips"}, {"@type": "ListItem", "position": 3, "name": "Ndarakwai Ranch", "item": "https://gokilimanjarotreks.com/daytrips/ndarakwai-ranch"}]}];
