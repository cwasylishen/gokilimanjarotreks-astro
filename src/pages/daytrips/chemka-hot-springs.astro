const schemas = [{"@context": "https://schema.org", "@type": "TouristTrip", "name": "Chemka Hot Springs", "description": "A relaxing day trip to Chemka (Kikuletwa) Hot Springs, warm turquoise pools under ancient fig trees, perfect after a safari or Kilimanjaro climb.", "provider": {"@id": "https://gokilimanjarotreks.com/#organization"}, "touristType": "Day-trip traveller", "url": "https://gokilimanjarotreks.com/daytrips/chemka-hot-springs", "duration": "P1D", "offers": {"@type": "Offer", "price": "85", "priceCurrency": "USD", "url": "https://gokilimanjarotreks.com/daytrips/chemka-hot-springs", "availability": "https://schema.org/InStock", "description": "Starting price per person"}}, {"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://gokilimanjarotreks.com/"}, {"@type": "ListItem", "position": 2, "name": "Day Trips", "item": "https://gokilimanjarotreks.com/daytrips"}, {"@type": "ListItem", "position": 3, "name": "Chemka Hot Springs", "item": "https://gokilimanjarotreks.com/daytrips/chemka-hot-springs"}]}];
