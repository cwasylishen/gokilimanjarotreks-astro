---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schemas = [{"@context": "https://schema.org", "@type": "TouristTrip", "name": "Materuni Waterfall and Coffee Farm Tour", "description": "A day trip from Moshi to the 80-metre Materuni Waterfall and a hands-on Chagga coffee experience on the lower slopes of Kilimanjaro.", "provider": {"@id": "https://gokilimanjarotreks.com/#organization"}, "touristType": "Day-trip traveller", "url": "https://gokilimanjarotreks.com/daytrips/materuni-waterfall-coffee", "duration": "P1D", "offers": {"@type": "Offer", "price": "91", "priceCurrency": "USD", "url": "https://gokilimanjarotreks.com/daytrips/materuni-waterfall-coffee", "availability": "https://schema.org/InStock", "description": "Starting price per person"}}, {"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://gokilimanjarotreks.com/"}, {"@type": "ListItem", "position": 2, "name": "Day Trips", "item": "https://gokilimanjarotreks.com/daytrips"}, {"@type": "ListItem", "position": 3, "name": "Materuni Waterfall and Coffee Farm Tour", "item": "https://gokilimanjarotreks.com/daytrips/materuni-waterfall-coffee"}]}];
---

<BaseLayout
  title="Materuni Waterfall & Coffee Tour | Go Kilimanjaro Treks"
  description="A day trip from Moshi to the 80-metre Materuni Waterfall and a hands-on Chagga coffee experience on the lower slopes of Kilimanjaro."
  ogImage="https://gokilimanjarotreks.com/images/daytrip-materuni.jpg"
  ogImageAlt="Materuni Falls near Moshi, on the lower slopes of Mount Kilimanjaro"
  schemas={schemas}
>

<section class="page-hero">
  <img src="/images/daytrip-materuni.jpg" alt="" aria-hidden="true" loading="eager" fetchpriority="high" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;z-index:0;opacity:0.55" />
  <div aria-hidden="true" style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(2,6,14,0.88) 0%,rgba(2,6,14,0.82) 40%,rgba(2,6,14,0.55) 65%,rgba(2,6,14,0.15) 100%);z-index:1"></div>
  <div class="container">
    <span class="page-hero-eyebrow">Tanzania Day Trip</span>
    <h1>Materuni Waterfall and Coffee Farm Tour</h1>
    <p>Immerse yourself in local culture and lush landscapes on the fertile lower slopes of Mount Kilimanjaro. This day trip combines a scenic hike through a green paradise to a stunning 80-meter waterfall with a hands-on, authentic look into the traditional coffee-making process of the Chagga people.</p>
    <div class="hero-ctas">
      <a href="/contact" class="btn-primary">Request a Quote &#x2192;</a>
      <a href="https://wa.me/255677917500" class="btn-ghost" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Nelson</a>
    </div>
  </div>
</section>

<section class="section-white">
  <div class="container" style="max-width:820px">
    <p style="font-size:1.15rem;color:var(--amber-cta);font-weight:700;margin:30px 0 18px">From $91 per person</p>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">Highlights</h2>
    <ul style="padding-left:22px;margin-bottom:8px">
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Hike through pristine tropical valleys to reach the thundering Materuni Waterfall.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Harvest, grind, and brew your own cup of organic coffee from scratch with local villagers.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Learn about the rich heritage, traditions, and agricultural lifestyle of the Chagga tribe.</li>
    </ul>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">A Day on This Trip</h2>
    <ol style="padding-left:22px;margin-bottom:8px">
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">08:00 AM: Travel from Arusha or Moshi to the historic village of Materuni.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">09:30 AM: Set off on a guided, 40-minute nature walk through local farmlands and lush valleys to the waterfall, where you can swim in the refreshing pool.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">12:30 PM: Head back to the village for a freshly prepared, authentic Chagga hot lunch.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">02:00 PM: Join local farmers in a lively, musical coffee-making session, learning everything from bean to cup.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">04:00 PM: Say goodbye to your hosts and drive back to your accommodation.</li>
    </ol>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">What is Included</h2>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Ground transport, local village and waterfall entry fees, professional local guide, traditional hot lunch, and the coffee-making experience.</p>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">What is Not Included</h2>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Tipping for village guides, personal gear (waterproof jacket/hiking shoes), and items of a personal nature.</p>
    <p style="font-size:.92rem;color:var(--muted);line-height:1.7;margin-top:18px">Every day trip is private and fully customisable. Prices vary with group size and season, so message Nelson for an exact quote for your dates.</p>
  </div>
</section>

