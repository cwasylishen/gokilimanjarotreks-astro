---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schemas = [{
  "@context":"https://schema.org","@type":"TouristTrip",
  "name":"Arusha National Park Day Trip",
  "description":"Tanzania day trip to Arusha National Park: Momela Lakes, Mount Meru foothills, walking safari country.",
