---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schemas = [{"@context": "https://schema.org", "@type": "TouristTrip", "name": "Arusha Safari", "description": "A day safari in Arusha National Park: walking safari with a ranger, the Momella Lakes, Ngurdoto Crater, and views of Meru and Kilimanjaro.", "provider": {"@id": "https://gokilimanjarotreks.com/#organization"}, "touristType": "Day-trip traveller", "url": "https://gokilimanjarotreks.com/daytrips/arusha-national-park", "duration": "P1D", "offers": {"@type": "Offer", "price": "263", "priceCurrency": "USD", "url": "https://gokilimanjarotreks.com/daytrips/arusha-national-park", "availability": "https://schema.org/InStock", "description": "Starting price per person"}}, {"@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://gokilimanjarotreks.com/"}, {"@type": "ListItem", "position": 2, "name": "Day Trips", "item": "https://gokilimanjarotreks.com/daytrips"}, {"@type": "ListItem", "position": 3, "name": "Arusha Safari", "item": "https://gokilimanjarotreks.com/daytrips/arusha-national-park"}]}];
---

<BaseLayout
  title="Arusha National Park Day Trip | Go Kilimanjaro Treks"
  description="A day safari in Arusha National Park: walking safari with a ranger, the Momella Lakes, Ngurdoto Crater, and views of Meru and Kilimanjaro."
  ogImage="https://gokilimanjarotreks.com/images/daytrip-arusha.jpg"
  ogImageAlt="Arusha National Park with Mount Meru"
  schemas={schemas}
>

<section class="page-hero">
  <img src="/images/daytrip-arusha.jpg" alt="" aria-hidden="true" loading="eager" fetchpriority="high" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;z-index:0;opacity:0.55" />
  <div aria-hidden="true" style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(2,6,14,0.88) 0%,rgba(2,6,14,0.82) 40%,rgba(2,6,14,0.55) 65%,rgba(2,6,14,0.15) 100%);z-index:1"></div>
  <div class="container">
    <span class="page-hero-eyebrow">Tanzania Day Trip</span>
    <h1>Arusha Safari</h1>
    <p>Perfect for travelers seeking a diverse and active safari experience without spending hours on the road. Located just a short drive from the city center, Arusha National Park packs a staggering variety of ecosystems, from dense montane rainforests to jagged volcanic cones and alkaline lakes, into a compact space.</p>
    <div class="hero-ctas">
      <a href="/contact" class="btn-primary">Request a Quote &#x2192;</a>
      <a href="https://wa.me/255677917500" class="btn-ghost" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Nelson</a>
    </div>
  </div>
</section>

<section class="section-white">
  <div class="container" style="max-width:820px">
    <p style="font-size:1.15rem;color:var(--amber-cta);font-weight:700;margin:30px 0 18px">From $263 per person</p>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">Highlights</h2>
    <ul style="padding-left:22px;margin-bottom:8px">
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Spot striking, rare black-and-white colobus monkeys jumping through the jungle canopy.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Walk safely alongside herds of zebras and buffaloes accompanied by an armed ranger.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:8px">Take in magnificent, sweeping views of Mount Meru and Mount Kilimanjaro on clear days.</li>
    </ul>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">A Day on This Trip</h2>
    <ol style="padding-left:22px;margin-bottom:8px">
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">08:00 AM: Short drive from Arusha town to the park gates.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">09:00 AM: Stretch your legs and walk amongst the wildlife on a unique, close-range foot safari with a national park ranger.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">12:00 PM: Drive out to the glittering Momella Lakes to watch flocks of flamingos, and enjoy a picnic lunch.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">01:30 PM: Tour the edge of the dramatic Ngurdoto Crater (often called &#39;Little Ngorongoro&#39;) to spot herds of giraffes, buffaloes, and warthogs.</li>
<li style="font-size:1rem;color:var(--text);line-height:1.7;margin-bottom:10px">04:30 PM: Depart the park and return to Arusha.</li>
    </ol>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">What is Included</h2>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">4x4 safari transport, park entrance fees, mandatory armed ranger fee for the walking safari, professional driver-guide, picnic lunch, and mineral water.</p>

    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">What is Not Included</h2>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Canoeing fees (optional add-on), tips, and personal expenses.</p>
    <p style="font-size:.92rem;color:var(--muted);line-height:1.7;margin-top:18px">Every day trip is private and fully customisable. Prices vary with group size and season, so message Nelson for an exact quote for your dates.</p>
  </div>
</section>

