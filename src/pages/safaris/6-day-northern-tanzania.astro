const schemas = [{
  "@context":"https://schema.org","@type":"TouristTrip",
  "name":"6-Day Northern Tanzania Safari",
  "description":"Six-day northern Tanzania safari across the major parks.",
  "provider":{"@id":"https://gokilimanjarotreks.com/#organization"},
  "touristType":"Wildlife safari traveller",
  "url":"https://gokilimanjarotreks.com/safaris/6-day-northern-tanzania"
