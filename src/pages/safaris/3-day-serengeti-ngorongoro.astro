---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schemas = [{
  "@context":"https://schema.org","@type":"TouristTrip",
  "name":"3-Day Safari: Serengeti & Ngorongoro",
  "description":"Three-day Tanzania safari covering Serengeti National Park and Ngorongoro Crater.",
  "provider":{"@id":"https://gokilimanjarotreks.com/#organization"},
  "touristType":"Wildlife safari traveller",
  "url":"https://gokilimanjarotreks.com/safaris/3-day-serengeti-ngorongoro"
}];
---

<BaseLayout
  title="3-Day Safari: Serengeti & Ngorongoro | Go Kilimanjaro Treks"
  description="Three-day Tanzania safari covering Serengeti National Park and Ngorongoro Crater."
  schemas={schemas}
>
<section class="page-hero">
  <div class="container">
    <span class="page-hero-eyebrow">Tanzania Safari Itinerary</span>
    <h1>3-Day Safari: Serengeti &amp; Ngorongoro.</h1>
    <p>Three-day Tanzania safari covering Serengeti National Park and Ngorongoro Crater.</p>
    <div class="hero-ctas">
      <a href="/contact" class="btn-primary">Request a Quote &#x2192;</a>
      <a href="https://wa.me/255677917500" class="btn-ghost" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Nelson</a>
    </div>
  </div>
</section>

<section class="section-white">
  <div class="container" style="max-width:820px">
    <h2 style="font-family:var(--font-display);font-size:1.5rem;font-weight:700;color:var(--amber-cta);margin:32px 0 12px">3: DAYS SAFARI - SERENGETI &amp; NGORONGORO</h2>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Discover the breathtaking landscapes and abundant wildlife of Tanzania's most iconic safari destinations. This safari combines the endless plains of Serengeti National Park with the spectacular Ngorongoro Crater, offering exceptional wildlife viewing and unforgettable African safari experiences.</p>
    <h3 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;color:var(--ink-2);margin:24px 0 8px">Day 1: Serengeti National Park</h3>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Depart from Arusha and journey through the scenic highlands towards Serengeti National Park. Upon arrival, enjoy an afternoon game drive across the vast plains of the Serengeti, renowned for its incredible wildlife diversity and spectacular landscapes.</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Wildlife sightings may include lions, leopards, cheetahs, elephants, giraffes, zebras, wildebeests, buffaloes, hyenas, and numerous antelope species.</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Accomodation : Baobab Serengeti Luxury Camp.</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Meal Plan: Full Board</p>
    <h3 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;color:var(--ink-2);margin:24px 0 8px">Day 2: Full Day Serengeti National Park</h3>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Spend a full day exploring different regions of the Serengeti, one of Africa's most celebrated wildlife sanctuaries. The park is home to an extraordinary concentration of predators and herbivores, making every game drive unique and exciting.</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Enjoy a picnic lunch in the bush while continuing your search for wildlife across the endless plains and river systems.</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Accommodation: Nyota Luxury Camp.</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Meal Plan: Full Board</p>
    <h3 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;color:var(--ink-2);margin:24px 0 8px">Day 3: Ngorongoro Crater -</h3>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">After breakfast, depart Serengeti and drive to the magnificent . Descend 600 meters into the crater for an unforgettable game drive.</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">The crater is home to an impressive concentration of wildlife including lions, elephants, buffaloes, zebras, wildebeests, hippos, hyenas, and the endangered black rhino. Its unique ecosystem offers one of the best wildlife viewing experiences in Africa.</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Enjoy a picnic lunch at a designated picnic site within the crater before continuing your safari.</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">In the late afternoon, drive back to Arusha for dinner and overnight.</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Accommodation : Forest Hill Hotel</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Meal Plan: Breakfast, Lunch &amp; Dinner</p>
    <h3 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;color:var(--ink-2);margin:24px 0 8px">Day 4: Departure</h3>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">After breakfast, transfer to the airport for your onward flight, marking the end of your memorable Tanzania safari adventure.</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">Meal Plan: Breakfast</p>
    <h3 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;color:var(--ink-2);margin:24px 0 8px">Price Included</h3>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• All park entrance fees and conservation fees</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Ngorongoro Crater service fee</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Professional English-speaking safari guide</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Private 4x4 safari vehicle with pop-up roof</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Accommodation as specified in the itinerary</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Meals as specified in the itinerary</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Bottled drinking water during safari</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Government taxes and VAT</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Airport transfers</p>
    <h3 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;color:var(--ink-2);margin:24px 0 8px">Not Included</h3>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• International and domestic flights</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Travel insurance</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Visa fees</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Alcoholic and soft drinks</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Tips and gratuities</p>
    <p style="font-size:1rem;color:var(--text);line-height:1.78;margin-bottom:14px">• Personal expenses and items of a personal nature</p>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2>Ready to <em>Plan This Safari</em>?</h2>
    <p>Talk to Nelson about your dates, group size, and what you most want to see. He responds personally within 24 hours.</p>
    <div class="cta-actions">
      <a href="/contact" class="btn-primary" style="font-size:1.05rem;padding:18px 40px">Request a Quote &#x2192;</a>
      <a href="https://wa.me/255677917500" class="btn-wa" style="font-size:1rem" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Now</a>
    </div>
  </div>
</section>
</BaseLayout>
