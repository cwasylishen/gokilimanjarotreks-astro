/safaris/7-day-classic-safari"},{"@type":"ListItem","position":9,"name":"8-Day Grand Safari","url":"https://gokilimanjarotreks.com/safaris/8-day-grand-safari"},{"@type":"ListItem","position":10,"name":"10-Day Tanzania Safari","url":"https://gokilimanjarotreks.com/safaris/10-day-tanzania-safari"},{"@type":"ListItem","position":11,"name":"14-Day Tanzania Safari","url":"https://gokilimanjarotreks.com/safaris/14-day-tanzania-safari"}]}];
---

<BaseLayout
  title="Tanzania Safari Itineraries | Go Kilimanjaro Treks"
  description="Pick from 11 Tanzania safari itineraries ranging from 3 days to two weeks, covering the Serengeti, Ngorongoro Crater, Tarangire, Lake Manyara, and Zanzibar."
  schemas={schemas}
>
  <style>
    .saf-grid{display:grid;gap:22px;margin-top:42px}
    @media(min-width:640px){.saf-grid{grid-template-columns:repeat(2,1fr)}}
    @media(min-width:1024px){.saf-grid{grid-template-columns:repeat(3,1fr)}}
    .saf-card{background:var(--white);border:1.5px solid var(--border);border-radius:16px;padding:26px;transition:transform .25s,border-color .25s,box-shadow .25s;display:flex;flex-direction:column;gap:10px}
    .saf-card:hover{transform:translateY(-3px);border-color:var(--amber-cta);box-shadow:0 18px 42px rgba(0,0,0,.08)}
    .saf-card h3{font-family:var(--font-display);font-size:1.2rem;color:var(--ink-2);font-weight:700;line-height:1.3}
    .saf-card p{font-size:.92rem;color:var(--muted);line-height:1.65;flex:1}
  </style>

  <section class="page-hero">
    <div class="container">
      <span class="page-hero-eyebrow">Tanzania Safaris</span>
      <h1>Safari <em>Itineraries.</em></h1>
      <p>11 ready-to-book Tanzania safari itineraries from 3 days to two weeks. Every itinerary is custom-tunable. Talk to Nelson and pick what fits your dates, group, and target wildlife.</p>
      <div class="hero-ctas">
        <a href="/contact" class="btn-primary">Plan My Safari &#x2192;</a>
        <a href="https://wa.me/255677917500" class="btn-ghost" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Nelson</a>
      </div>
    </div>
  </section>

  <section class="section-white">
    <div class="container">
      <div class="saf-grid">
        <a href="/safaris/3-day-tarangire-ngorongoro" class="saf-card">
  <h3>3-Day Safari: Tarangire &amp; Ngorongoro</h3>
  <p>Three-day Tanzania safari covering Tarangire National Park and Ngorongoro Crater.</p>
  <span style="color:var(--amber-cta);font-weight:600;font-size:.9rem">View Itinerary &#x2192;</span>
</a>
<a href="/safaris/3-day-serengeti-ngorongoro" class="saf-card">
  <h3>3-Day Safari: Serengeti &amp; Ngorongoro</h3>
  <p>Three-day Tanzania safari covering Serengeti National Park and Ngorongoro Crater.</p>
  <span style="color:var(--amber-cta);font-weight:600;font-size:.9rem">View Itinerary &#x2192;</span>
</a>
<a href="/safaris/4-day-northern-circuit" class="saf-card">
  <h3>4-Day Northern Circuit Safari</h3>
  <p>Four-day Tanzania northern-circuit safari with two nights in lodges.</p>
  <span style="color:var(--amber-cta);font-weight:600;font-size:.9rem">View Itinerary &#x2192;</span>
</a>
<a href="/safaris/4-day-tarangire-serengeti-ngorongoro" class="saf-card">
  <h3>4-Day Safari: Tarangire, Serengeti, Ngorongoro</h3>
  <p>Four-day Tanzania safari covering Tarangire, Serengeti and Ngorongoro.</p>
  <span style="color:var(--amber-cta);font-weight:600;font-size:.9rem">View Itinerary &#x2192;</span>
</a>
<a href="/safaris/5-day-tarangire-serengeti-ngorongoro" class="saf-card">
  <h3>5-Day Safari: Tarangire, Serengeti, Ngorongoro</h3>
  <p>Five-day Tanzania safari with extended Serengeti game viewing.</p>
  <span style="color:var(--amber-cta);font-weight:600;font-size:.9rem">View Itinerary &#x2192;</span>
</a>
<a href="/safaris/5-plus-2-day-safari-zanzibar" class="saf-card">
  <h3>5+2 Day Safari &amp; Zanzibar</h3>
  <p>Five-day Tanzania safari followed by two days on Zanzibar's beaches.</p>
  <span style="color:var(--amber-cta);font-weight:600;font-size:.9rem">View Itinerary &#x2192;</span>
</a>
<a href="/safaris/6-day-northern-tanzania" class="saf-card">
  <h3>6-Day Northern Tanzania Safari</h3>
  <p>Six-day northern Tanzania safari across the major parks.</p>
  <span style="color:var(--amber-cta);font-weight:600;font-size:.9rem">View Itinerary &#x2192;</span>
</a>
<a href="/safaris/7-day-classic-safari" class="saf-card">
  <h3>7-Day Classic Tanzania Safari</h3>
  <p>Seven-day classic Tanzania safari covering Lake Manyara, Serengeti, Ngorongoro and Tarangire.</p>
  <span style="color:var(--amber-cta);font-weight:600;font-size:.9rem">View Itinerary &#x2192;</span>
</a>
<a href="/safaris/8-day-grand-safari" class="saf-card">
  <h3>8-Day Grand Safari</h3>
  <p>Eight-day grand Tanzania safari with extended game viewing across all major parks.</p>
  <span style="color:var(--amber-cta);font-weight:600;font-size:.9rem">View Itinerary &#x2192;</span>
</a>
<a href="/safaris/10-day-tanzania-safari" class="saf-card">
  <h3>10-Day Tanzania Safari</h3>
  <p>Ten-day in-depth Tanzania safari across the Serengeti, Ngorongoro and supporting parks.</p>
  <span style="color:var(--amber-cta);font-weight:600;font-size:.9rem">View Itinerary &#x2192;</span>
</a>
<a href="/safaris/14-day-tanzania-safari" class="saf-card">
  <h3>14-Day Tanzania Safari</h3>
  <p>Two-week comprehensive Tanzania safari covering all major parks at a relaxed pace.</p>
  <span style="color:var(--amber-cta);font-weight:600;font-size:.9rem">View Itinerary &#x2192;</span>
</a>

      </div>
    </div>
  </section>
</BaseLayout>
