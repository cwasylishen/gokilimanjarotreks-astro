---

<BaseLayout
  title="4-Day Northern Circuit Safari | Go Kilimanjaro Treks"
  description="Four-day Tanzania northern-circuit safari with two nights in lodges."
  schemas={schemas}
>
<section class="page-hero">
  <div class="container">
    <span class="page-hero-eyebrow">Tanzania Safari Itinerary</span>
    <h1>4-Day Northern Circuit Safari.</h1>
    <p>Four-day Tanzania northern-circuit safari with two nights in lodges.</p>
    <div class="hero-ctas">
      <a href="/contact" class="btn-primary">Request a Quote &#x2192;</a>
      <a href="https://wa.me/255677917500" class="btn-ghost" target="_blank" rel="noopener">&#x1F4AC; WhatsApp Nelson</a>
    </div>
