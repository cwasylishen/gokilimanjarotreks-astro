const schemas = [{"@context":"https://schema.org","@graph":[{"@type":"ItemList","name":"Tanzania Day Trips from Moshi and Arusha","description":"Eleven single-day Tanzania excursions departing from Moshi and Arusha.","numberOfItems":11,"itemListOrder":"https://schema.org/ItemListOrderAscending","url":"https://gokilimanjarotreks.com/daytrips.html","dateModified":"2026-05-26","itemListElement":[{"@type":"ListItem","position":1,"url":"https://gokilimanjarotreks.com/daytrips/tarangire","name":"Tarangire Safari Tour"},{"@type":"ListItem","position":2,"url":"https://gokilimanjarotreks.com/daytrips/materuni-waterfall-coffee","name":"Materuni Waterfall and Coffee Farm Tour"},{"@type":"ListItem","position":3,"url":"https://gokilimanjarotreks.com/daytrips/arusha-national-park","name":"Arusha Safari"},{"@type":"ListItem","position":4,"url":"https://gokilimanjarotreks.com/daytrips/ol-doinyo-lengai","name":"Ol Doinyo Lengai"},{"@type":"ListItem","position":5,"url":"https://gokilimanjarotreks.com/daytrips/kilimanjaro-helicopter-tour","name":"Kilimanjaro Helicopter Tour"},{"@type":"ListItem","position":6,"url":"https://gokilimanjarotreks.com/daytrips/lake-chala","name":"Lake Chala"},{"@type":"ListItem","position":7,"url":"https://gokilimanjarotreks.com/daytrips/ndarakwai-ranch","name":"Ndarakwai Ranch"},{"@type":"ListItem","position":8,"url":"https://gokilimanjarotreks.com/daytrips/chemka-hot-springs","name":"Chemka Hot Springs"},{"@type":"ListItem","position":9,"url":"https://gokilimanjarotreks.com/daytrips/kilimanjaro-day-hike","name":"Mount Kilimanjaro Day Hikes"},{"@type":"ListItem","position":10,"url":"https://gokilimanjarotreks.com/daytrips/horseback-riding","name":"Horseback Riding"},{"@type":"ListItem","position":11,"url":"https://gokilimanjarotreks.com/daytrips/arusha-shopping-tour","name":"Arusha Shopping Tour"}]},{"@type":"TouristTrip","@id":"https://gokilimanjarotreks.com/daytrips/tarangire","name":"Tarangire Safari Tour","description":"Day safari into Tarangire National Park, famous for massive elephant herds and ancient baobab trees. Departs from Arusha.","image":"https://gokilimanjarotreks.com/images/daytrip-tarangire.jpg","url":"https://gokilimanjarotreks.com/daytrips/tarangire","touristType":["Wildlife enthusiasts","Photographers","Families"],"subjectOf":{"@id":"Tarangire National Park, Tanzania"},"provider":{"@type":"TravelAgency","@id":"https://gokilimanjarotreks.com/#organization","name":"Go Kilimanjaro Treks","url":"https://gokilimanjarotreks.com"},"offers":{"@type":"Offer","price":"245","priceCurrency":"USD","availability":"https://schema.org/InStock","url":"https://gokilimanjarotreks.com/contact.html","validFrom":"2026-01-01"},"duration":"PT9H"},{"@type":"TouristTrip","@id":"https://gokilimanjarotreks.com/daytrips/materuni-waterfall-coffee","name":"Materuni Waterfall and Coffee Farm Tour","description":"Cultural day trip on the lower slopes of Mount Kilimanjaro: hike to the 80-meter Materuni waterfall and join a Chagga coffee farm experience.","image":"https://gokilimanjarotreks.com/images/daytrip-materuni.jpg","url":"https://gokilimanjarotreks.com/daytrips/materuni-waterfall-coffee","touristType":["Cultural travelers","Hikers","Families"],"subjectOf":{"@id":"Materuni village, Kilimanjaro Region, Tanzania"},"provider":{"@type":"TravelAgency","@id":"https://gokilimanjarotreks.com/#organization","name":"Go Kilimanjaro Treks","url":"https://gokilimanjarotreks.com"},"offers":{"@type":"Offer","price":"91","priceCurrency":"USD","availability":"https://schema.org/InStock","url":"https://gokilimanjarotreks.com/contact.html","validFrom":"2026-01-01"},"duration":"PT8H"},{"@type":"TouristTrip","@id":"https://gokilimanjarotreks.com/daytrips/arusha-national-park","name":"Arusha Safari","description":"Day safari in Arusha National Park, including a walking safari with an armed ranger, Momella Lakes flamingos, and Ngurdoto Crater.","image":"https://gokilimanjarotreks.com/images/daytrip-arusha.jpg","url":"https://gokilimanjarotreks.co