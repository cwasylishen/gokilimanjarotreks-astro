---
import BaseLayout from '../layouts/BaseLayout.astro';
const schemas = [{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://gokilimanjarotreks.com/"},{"@type":"ListItem","position":2,"name":"Privacy Policy","item":"https://gokilimanjarotreks.com/privacy-policy.html"}],"dateModified":"2026-05-26"}];
---

<BaseLayout
  title="Privacy Policy | Go Kilimanjaro Treks"
  description="Privacy policy and booking information for Go Kilimanjaro Treks. Learn how we collect, use, and protect your personal information during your trek or safari booking."
  ogImage="https://gokilimanjarotreks.com/images/og-home.jpg"
  ogImageAlt="Go Kilimanjaro Treks"
  schemas={schemas}
>
  <main>
<section class="page-hero" style="background:var(--ink)">
  <img src="/images/page-hero-about.jpg" alt="" aria-hidden="true" loading="eager" fetchpriority="high" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center top;z-index:0;opacity:0.35">
  <div aria-hidden="true" style="position:absolute;inset:0;background:linear-gradient(100deg,rgba(2,6,14,0.97) 0%,rgba(2,6,14,0.94) 50%,rgba(2,6,14,0.80) 100%);z-index:1"></div>
  <div class="container" style="position:relative;z-index:2">
    <span class="page-hero-eyebrow">Your Data &bull; Your Rights</span>
    <h1>Privacy <em>Policy</em></h1>
    <p>We respect your privacy and are committed to protecting your personal information throughout your booking and travel experience with us.</p>
  </div>
</section>

<section style="background:var(--white)">
  <div class="container">
    <div class="policy-wrap">

      <p class="policy-intro">At Go Kilimanjaro Treks, your trust means everything. This policy explains exactly what information we collect, why we need it, and how we use and protect it. We keep things simple, secure, and transparent.</p>

      <!-- 1 -->
      <div class="policy-section">
        <span class="policy-num">Section 1</span>
        <h2>Personal Information We Collect</h2>
        <p>To successfully organise your trek, safari, or tour, we require the following details.</p>

        <p class="policy-subhead">Basic Personal Details</p>
        <ul class="policy-list">
          <li>Full name (as per passport)</li>
          <li>Nationality</li>
          <li>Date of birth</li>
          <li>Gender (optional)</li>
        </ul>

        <p class="policy-subhead">Contact Information</p>
        <ul class="policy-list">
          <li>Email address</li>
          <li>Phone number (including country code)</li>
          <li>Home address (optional, for documentation purposes)</li>
        </ul>

        <p class="policy-subhead">Passport Information</p>
        <ul class="policy-list">
          <li>Passport number</li>
          <li>Passport expiry date</li>
          <li>Country of issue</li>
        </ul>

        <div class="policy-note"><strong>Why we need this:</strong> Passport and contact details are required for park permits, hotel bookings, domestic flights, and official tourism regulations in Tanzania.</div>
      </div>

      <!-- 2 -->
      <div class="policy-section">
        <span class="policy-num">Section 2</span>
        <h2>Health &amp; Dietary Information</h2>
        <p>For your safety and comfort, especially during trekking and safaris, we may request:</p>
        <ul class="policy-list">
          <li>Pre-existing medical conditions</li>
          <li>Allergies (food, medication, environmental)</li>
          <li>Current medications</li>
          <li>Physical fitness level (for trekking suitability)</li>
          <li>Dietary preferences (vegetarian, vegan, halal, gluten-free, etc.)</li>
        </ul>
        <div class="policy-note"><strong>Why we need this:</strong> To ensure proper meal planning, emergency preparedness, and safe guidance during high-altitude trekking and safari activities.</div>
      </div>

      <!-- 3 -->
      <div class="policy-section">
        <span class="policy-num">Section 3</span>
        <h2>Emergency Contact Details</h2>
        <p>We require at least one emergency contact:</p>
        <ul class="policy-list">
          <li>Full name</li>
          <li>Relationship to traveller</li>
          <li>Phone number</li>
          <li>Email address (optional)</li>
        </ul>
        <div class="policy-note"><strong>Why we need this:</strong> To contact someone on your behalf in case of emergencies during your trip.</div>
      </div>

      <!-- 4 -->
      <div class="policy-section">
        <span class="policy-num">Section 4</span>
        <h2>Payment Information</h2>
        <p>To confirm your booking, we may collect:</p>
        <ul class="policy-list">
          <li>Payment method (bank transfer, card payment, mobile payment, etc.)</li>
          <li>Transaction details or proof of payment</li>
          <li>Billing name and address</li>
        </ul>
        <div class="policy-note"><strong>Important:</strong> We do not store sensitive financial information such as full credit card details. Payments are handled through secure and trusted payment systems.</div>
      </div>

      <!-- 5 -->
      <div class="policy-section">
        <span class="policy-num">Section 5</span>
        <h2>How We Use Your Information</h2>
        <p>Your information is used strictly for:</p>
        <ul class="policy-list">
          <li>Processing bookings and reservations</li>
          <li>Securing park permits and accommodations</li>
          <li>Organising transport and logistics</li>
          <li>Providing personalised services</li>
          <li>Ensuring your safety during tours</li>
          <li>Communicating important travel updates</li>
        </ul>
      </div>

      <!-- 6 -->
      <div class="policy-section">
        <span class="policy-num">Section 6</span>
        <h2>Data Protection &amp; Security</h2>
        <p>We take appropriate measures to protect your data, including secure storage of personal information and limited access restricted to authorised staff only. We do not sell or share your data with third parties for marketing purposes.</p>
        <p>We only share necessary information with service providers directly involved in your trip:</p>
        <ul class="policy-list">
          <li>National park authorities</li>
          <li>Hotels and lodges</li>
          <li>Transport providers</li>
        </ul>
      </div>

      <!-- 7 -->
      <div class="policy-section">
        <span class="policy-num">Section 7</span>
        <h2>Your Rights</h2>
        <p>You have the right to:</p>
        <ul class="policy-list">
          <li>Request access to your personal data</li>
          <li>Correct or update your information at any time</li>
          <li>Request deletion of your data after your trip</li>
        </ul>
        <p style="margin-top:16px">To exercise any of these rights, contact us directly at <a href="mailto:info@gokilimanjarotreks.com" style="color:var(--amber-cta);font-weight:600">info@gokilimanjarotreks.com</a>.</p>
      </div>

      <!-- 8 -->
      <div class="policy-section">
        <span class="policy-num">Section 8</span>
        <h2>Consent</h2>
        <p>By booking with Go Kilimanjaro Treks, you agree to the collection and use of your information as outlined in this policy. We will never use your data for any purpose beyond what is described here.</p>
      </div>

      <!-- 9 -->
      <div class="policy-section">
        <span class="policy-num">Section 9</span>
        <h2>Contact Us</h2>
        <p>If you have any questions about this policy or how your data is handled, get in touch directly:</p>
        <div class="contact-card">
          <p>
            <strong style="color:var(--white);font-family:'Cormorant Garamond',Georgia,serif;font-size:1.2rem">Go Kilimanjaro Treks</strong><br>
            Boma / Rindi Roads, Moshi, Tanzania<br>
            <a href="mailto:info@gokilimanjarotreks.com">info@gokilimanjarotreks.com</a><br>
            <a href="https://www.gokilimanjarotreks.com">www.gokilimanjarotreks.com</a><br>
            Office: <a href="tel:+255677917500">+255 677 917 500</a><br>
            Nelson: <a href="tel:+255713917500">+255 713 917 500</a>
          </p>
        </div>
      </div>

      <!-- Children -->
      <div class="policy-section">
        <span class="policy-num">Children's Policy</span>
        <h2>Travellers Under 18</h2>
        <p>Our services are not directed to children under the age of 18 without parental or guardian consent. We do not knowingly collect personal data from minors without proper authorisation. If such data is identified, we will take immediate steps to delete it.</p>
      </div>

      <!-- Updates -->
      <div class="policy-section">
        <span class="policy-num">Updates</span>
        <h2>Changes to This Policy</h2>
        <p>We reserve the right to update or modify this Privacy Policy at any time. Any changes will be posted on this page with an updated revision date. Continued use of our services after changes are posted constitutes your acceptance of the updated policy.</p>
        <p style="margin-top:16px;font-size:.88rem;color:var(--muted)">Last updated: May 2026</p>
      </div>

    </div>
  </div>
</section>
</main>

</BaseLayout>