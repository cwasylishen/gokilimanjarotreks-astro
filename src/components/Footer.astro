---
import { FOOTER_KILIMANJARO, FOOTER_PLAN, FOOTER_COMPANY } from '../data/nav';
import { SITE } from '../data/site';
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <img src="/images/logo.webp" alt={SITE.name} height="90" style="height:80px;width:auto;margin-bottom:12px;display:block">
        <p class="footer-tagline">{SITE.shortDescription}</p>
        <div class="footer-contact">
          <a href={`tel:${SITE.phoneIntl}`}>📞 {SITE.phone}</a>
          <a href={`mailto:${SITE.email}`}>✉️ {SITE.email}</a>
        </div>
      </div>
      <div class="footer-col">
        <h3>Kilimanjaro</h3>
        <ul>
          {FOOTER_KILIMANJARO.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h3>Plan Your Trip</h3>
        <ul>
          {FOOTER_PLAN.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h3>Company</h3>
        <ul>
          {FOOTER_COMPANY.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; <span id="year">2026</span> {SITE.name}. All rights reserved. &nbsp;·&nbsp;
        <a href="/privacy-policy" style="color:rgba(255,255,255,.35);text-decoration:underline">Privacy Policy</a> &nbsp;·&nbsp;
        <a href="/credits" style="color:rgba(255,255,255,.35);text-decoration:underline">Image Credits</a> &nbsp;·&nbsp;
        <a href="https://wizardweb.ca" target="_blank" rel="noopener" style="color:rgba(255,255,255,.35);text-decoration:underline">Built by WizardWeb</a>
      </p>
      <div class="social-links">
        <a href={SITE.social.facebook} aria-label="Facebook" target="_blank" rel="noopener">f</a>
        <a href={SITE.social.instagram} aria-label="Instagram" target="_blank" rel="noopener">in</a>
        <a href={SITE.whatsapp} aria-label="WhatsApp" target="_blank" rel="noopener">💬</a>
      </div>
    </div>
  </div>
</footer>
<a href={SITE.whatsapp} class="wa-float" target="_blank" rel="noopener" aria-label="Chat with us on WhatsApp">
  <svg viewBox="0 0 24 24" aria-hidden="true">
